{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard", "schedule:weekly"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": true, "schedule": ["before 6am on monday"] },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "rust crates"
    },
    {
      "description": "Performance-critical crates land in their own group so a bump that changes bench numbers gets a discrete PR — easier to bisect a regression to the right `BENCHMARKS.md` row.",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "divan",
        "iai-callgrind",
        "zune-jpeg",
        "zune-core",
        "fast_image_resize",
        "jpeg-encoder",
        "dhat",
        "tracing-flame",
        "wasm-bindgen-rayon"
      ],
      "groupName": "perf crates"
    },
    {
      "description": "Perf-tool binaries pinned via mise.toml's `cargo:NAME` entries. Renovate's mise manager picks these up automatically; grouping keeps their PRs visible alongside the cargo perf-crate bumps that often pair with them.",
      "matchManagers": ["mise"],
      "matchPackageNames": [
        "cargo:samply",
        "cargo:inferno",
        "cargo:iai-callgrind-runner",
        "cargo:hyperfine",
        "cargo:jq"
      ],
      "groupName": "perf crates"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm packages"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "pinDigests": true
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker base images"
    },
    {
      "description": "Project policy: track latest. Minor + patch bumps auto-merge once CI is green; only majors gate on human review.",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "lockFileMaintenance"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-bump"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump tools pinned via Dockerfile ARG with `# renovate:` comment",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+?)\\s+depName=(?<depName>[^\\s]+?)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\nARG\\s+[A-Z_]+_VERSION=(?<currentValue>.+)\\s*$"
      ]
    }
  ]
}
