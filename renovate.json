{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": true, "schedule": ["before 6am on monday"] },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "rust crates"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm packages"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "pinDigests": true
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker base images"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-bump"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump tools pinned via Dockerfile ARG with `# renovate:` comment",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+?)\\s+depName=(?<depName>[^\\s]+?)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\nARG\\s+[A-Z_]+_VERSION=(?<currentValue>.+)\\s*$"
      ]
    }
  ]
}
