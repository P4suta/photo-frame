/target
**/target
**/*.rs.bk
*.pdb

# Cargo
Cargo.lock.bak

# Node
node_modules
**/node_modules
**/pkg
**/dist
# Fonts mirrored from photo-frame-frame/assets/ into the web public/
# tree by `just copy-web-fonts`. Single source of truth stays in the
# frame crate; this directory is a build-time copy so Vite serves them
# from the bundle root.
crates/photo-frame-wasm/www/public/fonts/

# coi-serviceworker JS mirrored from node_modules by
# `just copy-coi-sw` (a sub-step of `just web-build`). Single source
# of truth is the npm package pinned in package.json; this copy is
# regenerated on every build and never belongs in git.
crates/photo-frame-wasm/www/public/coi-serviceworker.js
.vite
.cache
coverage

# Editor / OS
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.DS_Store
*.swp
*.swo

# Local secrets / env
.env
.env.local

# Lefthook artifacts
.lefthook-local.yml

# Claude Code local state (per-repo session log, scheduled tasks).
# Not project source; never belongs in the public history.
.claude/

# scripts/bench-build.sh and scripts/timings.sh write per-run artefacts
# under artifacts/. The committed `BENCHMARKS.md` carries the curated
# history; the raw json / html reports are local-only.
/artifacts/
!/artifacts/.gitkeep

# Sample photos live under samples/, split by role:
#   samples/bench/  — fixed filenames the bench harness reads by name
#                     (IMG_3936/3939/3940.JPG, see crates/photo-frame-bench/src/fixtures.rs)
#   samples/scratch/ — your own throwaway inputs for ad-hoc CLI runs
# Image binaries are never tracked in the repo (large, personal, and
# rarely the right shape for someone else's testing). Outputs from the
# CLI (`*_framed.jpg` etc.) belong outside samples/ — point `-o` at
# /tmp or another scratch path, not back into this tree.
samples/**/*.JPG
samples/**/*.JPEG
samples/**/*.jpg
samples/**/*.jpeg
samples/**/*.png
samples/**/*.PNG
